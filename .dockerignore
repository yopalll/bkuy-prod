# --- VCS / IDE ---
.git
.gitignore
.gitattributes
.idea
.vscode
.fleet

# --- Dependencies (rebuilt inside the image) ---
node_modules
vendor

# --- Compiled assets (rebuilt by the "assets" stage) ---
public/build
public/hot

# --- Local environment & secrets ---
.env
.env.*
!.env.example
auth.json

# --- GCS / service-account keys (mounted at runtime, never baked) ---
storage/app/gcp
storage/app/gcp-key.json

# --- Runtime / generated state ---
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php
public/storage
database/*.sqlite
database/*.sqlite-journal

# --- Tests / docs / tooling ---
tests
phpunit.xml
docker-compose*.yml
Dockerfile
.dockerignore
*.md
docs
