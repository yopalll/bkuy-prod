APP_NAME=BelajarKUY
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://belajarkuy.site
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ============================================================
# DATABASE — Docker service: mysql
# ============================================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=belajarkuy-prodj
DB_USERNAME=belajarkuy
DB_PASSWORD=
DB_ROOT_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# MAIL — Resend (SMTP)
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@mail.belajarkuy.site"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# MIDTRANS
# ============================================================
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_PRODUCTION=false
MIDTRANS_MERCHANT_ID=

# ============================================================
# GOOGLE OAUTH (Socialite)
# Tambahkan redirect URL ini di Google Cloud Console.
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://belajarkuy.site/auth/google-callback

# ============================================================
# CLOUDINARY
# ============================================================
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=belajarkuy_unsigned

# ============================================================
# MEILISEARCH — Docker service: meilisearch
# ============================================================
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

# ============================================================
# LARAVEL REVERB (WebSocket)
# REVERB_HOST di-override docker-compose ke "reverb" (internal).
# Nilai di sini dipakai sebagai build arg Vite (browser-side).
# ============================================================
REVERB_APP_ID=belajarkuy
REVERB_APP_KEY=belajarkuy-key
REVERB_APP_SECRET=
REVERB_HOST=belajarkuy.site
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

VITE_APP_NAME="${APP_NAME}"

# ============================================================
# AWS (unused)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================
# GOOGLE CLOUD STORAGE (GCS)
# Key file di-mount via Docker volume (./storage/app/gcp).
# ============================================================
GCP_PROJECT_ID=
GCP_BUCKET_NAME=
GCP_KEY_FILE_PATH=storage/app/gcp/gcp-key.json
