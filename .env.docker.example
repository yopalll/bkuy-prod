# =============================================================================
# BelajarKUY — Docker .env reference
#
# Copy your existing .env and apply the values below (the ones not overridden
# here by docker-compose are still read from .env, e.g. APP_KEY, MIDTRANS,
# GOOGLE, CLOUDINARY, GCP, RESEND keys).
#
#   cp .env.example .env       # if you don't have one yet
#   docker compose run --rm app php artisan key:generate   # sets APP_KEY
#
# NOTE: hostnames (DB_HOST, REDIS_HOST, MEILISEARCH_HOST...) and the cache/
#       session/queue drivers are injected by docker-compose, so you don't
#       strictly need to set them here — but keep them consistent for clarity.
# =============================================================================

APP_NAME=BelajarKUY
APP_ENV=production
APP_KEY=                       # <-- generate it (see above)
APP_DEBUG=false
APP_URL=http://belajarkuy.site          # https://belajarkuy.site after SSL
APP_TIMEZONE=Asia/Jakarta

# --- Database (MySQL container) -------------------------------------------
# These are read by BOTH the app and the mysql service. Pick strong secrets.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=belajarkuy
DB_USERNAME=belajarkuy
DB_PASSWORD=change-me-please
DB_ROOT_PASSWORD=change-me-root-please   # used only by the mysql container

# --- Redis (cache / sessions / queue / reverb scaling) --------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# --- Meilisearch ----------------------------------------------------------
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=change-me-meili-master-key

# --- Broadcasting / Reverb ------------------------------------------------
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=belajarkuy
REVERB_APP_KEY=belajarkuy-key
REVERB_APP_SECRET=change-me-reverb-secret
# Public endpoint the browser + server publish to (proxied by Nginx).
# Before SSL: port 80 / http. After SSL: port 443 / https (then rebuild app).
REVERB_HOST=belajarkuy.site
REVERB_PORT=80
REVERB_SCHEME=http
REVERB_SCALING_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --- Mail (Resend recommended for prod) -----------------------------------
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="noreply@belajarkuy.site"
MAIL_FROM_NAME="${APP_NAME}"

# --- Third-party (fill from your dashboards) ------------------------------
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://belajarkuy.site/auth/google-callback

CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=belajarkuy_unsigned

# --- Google Cloud Storage --------------------------------------------------
# Place the JSON key at:  storage/app/gcp/service-account.json
# (the directory is bind-mounted read-only into the containers).
GCP_PROJECT_ID=
GCP_BUCKET_NAME=
GCP_KEY_FILE_PATH=storage/app/gcp/service-account.json
